#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper startup shell script, version 3.2.0
# ----------------------------------------------------------------------------

set -e

# Determine base directory
if [ -z "$MAVEN_BASEDIR" ]; then
    MAVEN_PROJECTBASEDIR=$(cd "$(dirname "$0")" && pwd)
else
    MAVEN_PROJECTBASEDIR="$MAVEN_BASEDIR"
fi

WRAPPER_DIR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper"
WRAPPER_PROPERTIES="$WRAPPER_DIR/maven-wrapper.properties"
MAVEN_WRAPPER_JAR="$WRAPPER_DIR/maven-wrapper.jar"

# Read properties
DISTRIBUTION_URL=""
DOWNLOAD_URL=""
if [ -f "$WRAPPER_PROPERTIES" ]; then
    DISTRIBUTION_URL=$(grep distributionUrl "$WRAPPER_PROPERTIES" | cut -d= -f2-)
    DOWNLOAD_URL=$(grep wrapperUrl "$WRAPPER_PROPERTIES" | cut -d= -f2-)
fi

# Download wrapper jar if missing
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
    if [ -n "$DOWNLOAD_URL" ]; then
        if command -v curl > /dev/null 2>&1; then
            curl -sL "$DOWNLOAD_URL" -o "$MAVEN_WRAPPER_JAR"
        elif command -v wget > /dev/null 2>&1; then
            wget -q "$DOWNLOAD_URL" -O "$MAVEN_WRAPPER_JAR"
        else
            echo "Error: Cannot download maven-wrapper.jar. Install curl or wget."
            exit 1
        fi
    fi
fi

# Locate java
if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

exec "$JAVACMD" $MAVEN_OPTS \
    -classpath "$MAVEN_WRAPPER_JAR" \
    "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
    org.apache.maven.wrapper.MavenWrapperMain "$@"
